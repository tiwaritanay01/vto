{
  "version": 2,
  "buildCommand": "cd \"vto frontend\" && npm install && npm run build",
  "outputDirectory": "vto frontend/dist",
  "installCommand": "cd \"vto frontend\" && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/vto/tryon",
      "destination": "/api/vto/tryon.py"
    }
  ],
  "functions": {
    "api/vto/tryon.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    }
  }
}
